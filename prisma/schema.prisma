generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model Domain {
  id         String   @id @default(cuid())
  name       String   @unique           // enforces no duplicates
  tld        String
  length     Int
  aby        Int?                        // Archive.org age (years)
  wby        Int?                        // Whois age (years)
  backlinks  Int?
  dropDate   DateTime?
  scrapedAt  DateTime @default(now())
  createdAt  DateTime @default(now())
}

model ScrapeRun {
  id         String   @id @default(cuid())
  startedAt  DateTime @default(now())
  finishedAt DateTime?
  status     String   // "running" | "success" | "failed"
  count      Int?
  error      String?
}
